---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
	formatDate,
	getPublishedPosts,
	withBase,
	type BlogPost,
} from '../../lib/posts';

export function getStaticPaths() {
	const posts = getPublishedPosts();
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

interface Props {
	post: BlogPost;
}

const { post } = Astro.props;
const Content = post.Content as any;
---

<BaseLayout title={post.data.title} description={post.data.description}>
	<article class="site-shell">
		<p class="eyebrow">{post.data.category}</p>
		<h1 class="page-title">{post.data.title}</h1>
		<div class="meta">
			<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
			<span>{post.data.description}</span>
		</div>
		<div class="chip-row" style="margin: 1.25rem 0 2rem;">
			<a class="chip" href={withBase(`/blog/category/${encodeURIComponent(post.data.category)}/`)}>
				{post.data.category}
			</a>
			{
				post.data.tags.map((tag) => (
					<a class="chip" href={withBase(`/blog/tag/${encodeURIComponent(tag)}/`)}>
						#{tag}
					</a>
				))
			}
		</div>
		<div class="prose">
			<Content />
		</div>
		<p style="margin-top: 3rem;">
			<a class="btn btn-ghost" href={withBase('/blog')}>← Blog 목록</a>
		</p>
	</article>
</BaseLayout>
