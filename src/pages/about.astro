---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/posts';
import blogicon from '../assets/blogicon.js';
---

<BaseLayout title="About" description="Cursor Notes 소개">
	<article class="site-shell">
		<div class="about-brand">
			<img
				class="about-brand__icon"
				src={blogicon}
				alt="Cursor Notes 대표 아이콘"
				width="88"
				height="99"
				decoding="async"
			/>
			<div>
				<p class="eyebrow">About</p>
				<h1 class="page-title">이 블로그에 대하여</h1>
			</div>
		</div>
		<p class="lead">
			Cursor Notes는 Astro Content Collections와 GitHub Pages로 만든 실습용 정적 블로그입니다.
			기존 <code>username.github.io</code> 사이트와 분리된 프로젝트 Pages로 운영합니다.
		</p>

		<h2>기술 스택</h2>
		<ul>
			<li>Astro — 정적 사이트 생성</li>
			<li>Markdown — 글 작성</li>
			<li>GitHub Actions — 자동 배포</li>
			<li>GitHub Pages — 호스팅</li>
		</ul>

		<h2>글 관리 방식</h2>
		<p>
			글 파일은 <code>src/content/blog/YYYY/MM/</code> 아래에 두고, frontmatter에
			<strong>category</strong>와 <strong>tags</strong>를 적어 분류합니다.
		</p>

		<p style="margin-top: 2rem;">
			<a class="btn" href={withBase('/blog')}>글 목록으로</a>
		</p>
	</article>
</BaseLayout>
